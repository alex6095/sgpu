#!/usr/bin/env bash
# sgpu — thin client for the in-pod sgpu monitor.
# All rendering happens server-side; this script only shells out to kubectl.
set -euo pipefail

namespace="${SGPU_NAMESPACE:-p-sgvr-node-02}"
pod="${SGPU_POD:-sangmin-gpu-monitor}"
interval="${SGPU_INTERVAL:-2}"
no_color="${SGPU_NO_COLOR:-0}"
cmd=""
arg=""

usage() {
  cat <<'EOF'
usage: sgpu [command] [options]

commands:
  (none) | top     interactive TUI (scroll, sort, owner filter)
  once             one-shot dashboard
  watch [sec]      simple refresh loop (for dumb terminals)
  apps             GPU process table with pod owners
  stats [days]     per-owner usage report (default 7 days)
  nvitop           raw nvitop TUI
  pods | smi | gpustat | json | health | version

options:
  -n, --namespace NS   kubernetes namespace   (default p-sgvr-node-02)
      --pod NAME       monitor pod name       (default sangmin-gpu-monitor)
  -r, --refresh SEC    TUI/watch refresh interval (default 2)
      --no-color       disable ANSI colors
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--namespace) namespace="${2:?missing namespace}"; shift 2 ;;
    --pod) pod="${2:?missing pod}"; shift 2 ;;
    -r|--refresh|--interval) interval="${2:?missing seconds}"; shift 2 ;;
    --no-color) no_color=1; shift ;;
    -h|--help|help) usage; exit 0 ;;
    top|once|watch|apps|stats|nvitop|pods|smi|gpustat|json|health|version)
      cmd="$1"; shift ;;
    ''|*[!0-9]*)
      echo "sgpu: unknown argument: $1" >&2; usage >&2; exit 2 ;;
    *) arg="$1"; shift ;;  # bare number: days for stats, seconds for watch
  esac
done

hint_on_failure() {
  echo "sgpu: cannot reach monitor pod '$pod' in namespace '$namespace'" >&2
  printf '%s\n' "$1" | tail -n 3 >&2
  if grep -qiE 'not ?found' <<<"$1"; then
    cat >&2 <<EOF
hint: the monitor pod is not running. Deploy it with:
  kubectl apply -f https://raw.githubusercontent.com/alex6095/sgpu/main/k8s/gpu-monitor.yaml
EOF
  elif grep -qiE 'unauthorized|forbidden|credentials' <<<"$1"; then
    echo "hint: check your access: kubectl auth can-i get pods -n $namespace" >&2
  fi
}

kfetch() {
  local out
  if ! out="$(kubectl exec -n "$namespace" "$pod" -- \
      curl -fsS "http://127.0.0.1:8080$1" 2>&1)"; then
    hint_on_failure "$out"
    return 1
  fi
  printf '%s\n' "$out"
}

color_param() {
  if [[ "$no_color" == "0" && -t 1 ]]; then printf 'color=1'; else printf 'color=0'; fi
}

cols_param() {
  local cols
  cols="$(tput cols 2>/dev/null || true)"
  [[ -n "$cols" && "$cols" -ge 40 ]] || cols=120
  printf 'cols=%s' "$cols"
}

interactive() {
  exec kubectl exec -it -n "$namespace" "$pod" -- "$@"
}

watch_loop() {
  local esc frame
  esc="$(printf '\033')"
  printf '%s[?1049h%s[?25l' "$esc" "$esc"
  trap 'printf "\033[?25h\033[?1049l"' EXIT INT TERM
  while true; do
    frame="$(kfetch "/table?$(color_param)&$(cols_param)")" \
      || frame="sgpu: fetch failed; retrying..."
    printf '%s[H%s\n%s[0J' "$esc" "$frame" "$esc"
    sleep "${arg:-$interval}"
  done
}

case "$cmd" in
  ""|top)  interactive python3 /opt/gpu-monitor/tui.py "$interval" ;;
  nvitop)  interactive nvitop ;;
  once)    kfetch "/table?$(color_param)&$(cols_param)" ;;
  watch)   watch_loop ;;
  apps)    kfetch "/apps?$(color_param)&$(cols_param)" ;;
  stats)   kfetch "/stats?days=${arg:-7}&$(color_param)&$(cols_param)" ;;
  pods)    kfetch "/pods" ;;
  smi)     kfetch "/smi" ;;
  gpustat) kfetch "/gpustat" ;;
  json)    kfetch "/json" ;;
  health)  kfetch "/health" ;;
  version) kfetch "/version" ;;
esac
