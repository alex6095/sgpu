#!/usr/bin/env bash
set -euo pipefail

interval="${SGPU_INTERVAL:-2}"
port="${SGPU_PORT:-18080}"
namespace="${SGPU_NAMESPACE:-p-sgvr-node-02}"
service="${SGPU_SERVICE:-sangmin-gpu-monitor}"
pod="${SGPU_POD:-sangmin-gpu-monitor}"
share="${SGPU_SHARE_ON_LAN:-0}"
transport="${SGPU_TRANSPORT:-exec}"
no_color="${SGPU_NO_COLOR:-0}"
cmd="top"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --exec)
      transport="exec"
      shift
      ;;
    --port-forward|--pf)
      transport="port-forward"
      shift
      ;;
    -r|--refresh|--interval)
      interval="${2:?missing refresh seconds}"
      shift 2
      ;;
    --namespace)
      namespace="${2:?missing namespace}"
      shift 2
      ;;
    --service)
      service="${2:?missing service}"
      shift 2
      ;;
    --pod)
      pod="${2:?missing pod}"
      shift 2
      ;;
    --port)
      port="${2:?missing port}"
      shift 2
      ;;
    --no-color)
      no_color="1"
      shift
      ;;
    top|once|smi|apps|pods|gpustat|url|status|stop)
      cmd="$1"
      shift
      ;;
    ''|*[!0-9]*)
      echo "sgpu: unknown argument: $1" >&2
      exit 2
      ;;
    *)
      interval="$1"
      shift
      ;;
  esac
done

if [[ "$cmd" == "url" ]]; then
  transport="port-forward"
fi

script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
  dir="$(cd -P "$(dirname "$script_path")" && pwd)"
  script_path="$(readlink "$script_path")"
  [[ "$script_path" != /* ]] && script_path="$dir/$script_path"
done
repo_root="$(cd -P "$(dirname "$script_path")/.." && pwd)"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/sgpu"
mkdir -p "$cache_dir"
pid_file="$cache_dir/port-forward.pid"
addr_file="$cache_dir/port-forward.address"
out_log="$cache_dir/port-forward.out.log"
err_log="$cache_dir/port-forward.err.log"
address="127.0.0.1"
if [[ "$share" == "1" || "$share" == "true" ]]; then
  address="0.0.0.0"
fi
base_url="http://127.0.0.1:${port}"

is_running() {
  [[ -f "$pid_file" ]] || return 1
  local pid
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

health_ok() {
  curl -fsS --max-time 2 "$base_url/health" >/dev/null 2>&1
}

stop_tunnel() {
  if is_running; then
    kill "$(cat "$pid_file")" 2>/dev/null || true
  fi
  rm -f "$pid_file" "$addr_file" "$out_log" "$err_log"
}

ensure_tunnel() {
  if [[ "$transport" == "exec" ]]; then
    return 0
  fi
  if is_running && [[ -f "$addr_file" ]] && [[ "$(cat "$addr_file")" == "$address" ]] && health_ok; then
    return 0
  fi
  stop_tunnel
  kubectl -n "$namespace" port-forward "svc/$service" "${port}:8080" --address "$address" >"$out_log" 2>"$err_log" &
  echo "$!" >"$pid_file"
  echo "$address" >"$addr_file"
  for _ in $(seq 1 24); do
    health_ok && return 0
    sleep 0.5
  done
  echo "sgpu: port-forward started but health check failed" >&2
  tail -80 "$out_log" "$err_log" >&2 || true
  return 1
}

fetch() {
  local path="$1"
  if [[ "$transport" == "exec" ]]; then
    kubectl exec -n "$namespace" "$pod" -- bash -lc "curl -fsS 'http://127.0.0.1:8080$path'" 2>&1
    return
  fi
  if ! curl -fsS --max-time 5 "$base_url$path"; then
    ensure_tunnel >/dev/null
    curl -fsS --max-time 8 "$base_url$path"
  fi
}

kube_pods() {
  local node
  node="$(kubectl get pod "$pod" -n "$namespace" -o jsonpath='{.spec.nodeName}' 2>/dev/null || true)"
  # Let python invoke kubectl itself. Passing the full pod JSON through an
  # environment variable overflows ARG_MAX on busy namespaces (python3:
  # "Argument list too long"), which silently drops this table on Linux.
  NODE_FILTER="$node" SGPU_NS="$namespace" python3 - <<'PY'
import datetime as dt
import json
import os
import subprocess

def gpu_request(pod):
    total = 0
    for container in pod.get("spec", {}).get("containers", []):
        res = container.get("resources", {})
        value = res.get("requests", {}).get("nvidia.com/gpu") or res.get("limits", {}).get("nvidia.com/gpu") or 0
        try:
            total += int(value)
        except Exception:
            pass
    return total

def owner(name):
    return (name or "?").replace("_", "-").split("-", 1)[0]

def age(start):
    if not start:
        return "?"
    try:
        started = dt.datetime.fromisoformat(start.replace("Z", "+00:00"))
    except Exception:
        return "?"
    seconds = max(0, int((dt.datetime.now(dt.timezone.utc) - started).total_seconds()))
    days, seconds = divmod(seconds, 86400)
    hours, seconds = divmod(seconds, 3600)
    minutes = seconds // 60
    if days:
        return f"{days}d{hours}h"
    if hours:
        return f"{hours}h{minutes}m"
    return f"{minutes}m"

node = os.environ.get("NODE_FILTER", "")
namespace = os.environ.get("SGPU_NS", "p-sgvr-node-02")
try:
    raw = subprocess.check_output(
        ["kubectl", "get", "pods", "-n", namespace, "-o", "json"],
        text=True,
    )
    data = json.loads(raw)
except Exception as exc:
    print()
    print(f"Kubernetes GPU pods from local kubectl: unavailable ({exc})")
    raise SystemExit(0)
rows = []
for pod in data.get("items", []):
    phase = pod.get("status", {}).get("phase", "")
    if phase not in ("Running", "Pending"):
        continue
    if node and pod.get("spec", {}).get("nodeName") != node:
        continue
    gpu = gpu_request(pod)
    if gpu <= 0:
        continue
    name = pod.get("metadata", {}).get("name", "")
    rows.append((owner(name), gpu, age(pod.get("status", {}).get("startTime")), phase, name))

print()
print("Kubernetes GPU pods from local kubectl")
print("OWNER    GPU  AGE     PHASE    POD")
print("-------  ---  ------  -------  ----------------------------------------")
if not rows:
    print("(no Running/Pending GPU-requesting pods found)")
for row in sorted(rows):
    print(f"{row[0][:7]:<7}  {row[1]:>3}  {row[2]:<6}  {row[3]:<7}  {row[4]}")
PY
}

dashboard() {
  fetch /table
  kube_pods
}

terminal_cols() {
  local cols
  cols="$(tput cols 2>/dev/null || true)"
  if [[ -z "$cols" || "$cols" -lt 20 ]]; then
    cols=100
  fi
  printf '%s' "$cols"
}

terminal_rows() {
  local rows
  rows="$(tput lines 2>/dev/null || true)"
  if [[ -z "$rows" || "$rows" -lt 8 ]]; then
    rows=24
  fi
  printf '%s' "$rows"
}

limit_line() {
  local line="$1"
  local cols="$2"
  local max=$((cols - 1))
  if (( max < 1 )); then
    return 0
  fi
  if (( ${#line} <= max )); then
    printf '%s' "$line"
  elif (( max == 1 )); then
    printf '>'
  else
    printf '%s>' "${line:0:max-1}"
  fi
}

color() {
  if [[ "$no_color" == "1" || ! -t 1 ]]; then
    return 0
  fi
  case "$1" in
    reset) printf '\033[0m' ;;
    bold) printf '\033[1m' ;;
    dim) printf '\033[2m' ;;
    cyan) printf '\033[36m' ;;
    green) printf '\033[32m' ;;
    yellow) printf '\033[33m' ;;
    red) printf '\033[31m' ;;
    magenta) printf '\033[35m' ;;
  esac
}

style_line() {
  local line="$1"
  if [[ "$no_color" == "1" || ! -t 1 ]]; then
    printf '%s' "$line"
    return 0
  fi
  if [[ "$line" =~ ^(SGPU[[:space:]]+)?MLXP\ GPU\ monitor ]]; then
    color bold; color cyan; printf '%s' "$line"; color reset
  elif [[ "$line" =~ ^(NVIDIA\ compute\ processes|Kubernetes\ GPU\ pods) ]]; then
    color bold; color magenta; printf '%s' "$line"; color reset
  elif [[ "$line" =~ ^(GPU[[:space:]]+Name|OWNER[[:space:]]+GPU|GPU[[:space:]]+UUID) ]]; then
    color bold; printf '%s' "$line"; color reset
  elif [[ "$line" =~ ^--- ]]; then
    color dim; printf '%s' "$line"; color reset
  elif [[ "$line" =~ ^[[:space:]]*[0-9]+[[:space:]]+NVIDIA && "$line" =~ [[:space:]]([0-9]+)% ]]; then
    local util="${BASH_REMATCH[1]}"
    if (( util >= 90 )); then
      color red
    elif (( util >= 50 )); then
      color yellow
    else
      color green
    fi
    printf '%s' "$line"; color reset
  elif [[ "$line" =~ ^refresh= ]]; then
    color dim; printf '%s' "$line"; color reset
  else
    printf '%s' "$line"
  fi
}

draw_frame() {
  local frame="$1"
  local esc="$2"
  local cols rows max_rows row_count i line
  cols="$(terminal_cols)"
  rows="$(terminal_rows)"
  max_rows=$((rows - 1))
  frame="${frame//$'\r'/}"
  mapfile -t frame_lines <<< "$frame"
  row_count="${#frame_lines[@]}"
  if (( row_count > max_rows )); then
    row_count="$max_rows"
  fi
  printf '%s[H' "$esc"
  for ((i = 0; i < row_count; i++)); do
    line="${frame_lines[$i]}"
    if [[ "$line" == "MLXP GPU monitor"* ]]; then
      line="SGPU  $line"
    fi
    printf '%s[2K' "$esc"
    style_line "$(limit_line "$line" "$cols")"
    if (( i < row_count - 1 )); then
      printf '\n'
    fi
  done
  printf '%s[J' "$esc"
}

render_top() {
  ensure_tunnel >/dev/null
  local esc
  esc="$(printf '\033')"
  printf '%s[?1049h%s[?25l%s[2J%s[H' "$esc" "$esc" "$esc" "$esc"
  trap 'printf "\033[?25h\033[?1049l"' EXIT INT TERM
  while true; do
    local frame
    frame="$(
      dashboard || true
      printf '\nrefresh=%ss  transport=%s  commands: sgpu once | sgpu smi | sgpu apps | sgpu stop\n' "$interval" "$transport"
    )"
    draw_frame "$frame" "$esc"
    sleep "$interval"
  done
}

case "$cmd" in
  stop)
    stop_tunnel
    echo "sgpu tunnel stopped"
    ;;
  status)
    if [[ "$transport" == "exec" ]]; then
      echo "sgpu default transport=exec; no local port-forward is used for top/once/smi/apps."
      if is_running; then
        echo "existing tunnel pid=$(cat "$pid_file") address=$(cat "$addr_file" 2>/dev/null || echo "?") health=$(health_ok && echo true || echo false)"
      else
        echo "existing tunnel is not running"
      fi
    elif is_running; then
      echo "sgpu tunnel pid=$(cat "$pid_file") address=$(cat "$addr_file" 2>/dev/null || echo "?") health=$(health_ok && echo true || echo false)"
      echo "$base_url/smi"
    else
      echo "sgpu tunnel is not running"
    fi
    ;;
  url)
    ensure_tunnel >/dev/null
    printf '%s\n' "$base_url/table" "$base_url/smi" "$base_url/apps"
    ;;
  once)
    ensure_tunnel >/dev/null
    dashboard
    ;;
  smi)
    ensure_tunnel >/dev/null
    fetch /smi
    ;;
  apps)
    ensure_tunnel >/dev/null
    fetch /apps
    ;;
  pods)
    ensure_tunnel >/dev/null
    fetch /pods
    ;;
  gpustat)
    ensure_tunnel >/dev/null
    fetch /gpustat
    ;;
  top)
    render_top
    ;;
  *)
    echo "usage: sgpu [--exec|--port-forward] [-r seconds] [top|once|smi|apps|pods|gpustat|url|status|stop]" >&2
    exit 2
    ;;
esac
